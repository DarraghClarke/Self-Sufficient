<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

        <PreferenceCategory
            app:key="general_category"
            app:title="General">

<!--                <SwitchPreferenceCompat-->
<!--                    app:key="notifications"-->
<!--                    app:title="Enable message notifications"/>-->
        </PreferenceCategory>

        <PreferenceCategory
            app:key="water_category"
            app:title="Water">

            <SwitchPreference
                android:defaultValue="false"
                android:key="using_water"
                android:title="Using Water?" />
            <EditTextPreference
                    app:key="roof_area"
                    app:useSimpleSummaryProvider="true"
                    app:title="Roof area" />

                <EditTextPreference
                    app:key="water_tank_size"
                    app:useSimpleSummaryProvider="true"
                    app:title="Water tank size" />
        </PreferenceCategory>

    <PreferenceCategory
        app:key="solar_category"
        app:title="Solar">
        <SwitchPreference
            android:defaultValue="false"
            android:key="using_solar"
            android:title="Using Solar?" />
        <EditTextPreference
            app:key="solar_panel_output"
            app:useSimpleSummaryProvider="true"
            app:title="Solar panel output" />

        <EditTextPreference
            app:key="kwh_rate"
            app:useSimpleSummaryProvider="true"
            app:title="KW/h rate" />
    </PreferenceCategory>
</PreferenceScreen>