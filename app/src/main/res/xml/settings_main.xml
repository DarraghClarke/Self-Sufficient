<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:key="general_category"
        app:title="General">

        <SwitchPreferenceCompat
            app:key="notifications"
            app:title="Enable message notifications"/>

        <EditTextPreference
            app:key="ROOF_AREA"
            app:useSimpleSummaryProvider="true"
            app:title="Roof area" />

    </PreferenceCategory>

    <PreferenceCategory
        app:key="water_category"
        app:title="Water">
    <ListPreference
        app:defaultValue="@string/settings_order_by_default"
        app:entries="@array/settings_order_by_labels"
        app:entryValues="@array/settings_order_by_values"
        app:useSimpleSummaryProvider="true"
        app:key="@string/settings_order_by_key"
        app:title="@string/settings_order_by_label" />
    </PreferenceCategory>

    <PreferenceCategory
        app:key="solar_category"
        app:title="Solar category">
        <ListPreference
            app:defaultValue="@string/settings_order_by_default"
            app:entries="@array/settings_order_by_labels"
            app:entryValues="@array/settings_order_by_values"
            app:useSimpleSummaryProvider="true"
            app:key="@string/settings_order_by_key"
            app:title="@string/settings_order_by_label" />
    </PreferenceCategory>
</PreferenceScreen>