<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

        <PreferenceCategory
            app:key="general_category"
            app:title="General">

<!--                <SwitchPreferenceCompat-->
<!--                    app:key="notifications"-->
<!--                    app:title="Enable message notifications"/>-->
        </PreferenceCategory>

        <PreferenceCategory
            app:key="water_category"
            app:title="Water">

                <EditTextPreference
                    app:key="roof_area"
                    app:useSimpleSummaryProvider="true"
                    app:title="Roof area" />

                <EditTextPreference
                    app:key="water_tank_size"
                    app:useSimpleSummaryProvider="true"
                    app:title="Water tank size" />
        </PreferenceCategory>

    <PreferenceCategory
        app:key="solar_category"
        app:title="Solar">
        <EditTextPreference
            app:key="solar_panel_output"
            app:useSimpleSummaryProvider="true"
            app:title="Solar panel output" />

        <EditTextPreference
            app:key="kwh_rate"
            app:useSimpleSummaryProvider="true"
            app:title="KW/h rate" />
    </PreferenceCategory>
</PreferenceScreen>